generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Blog {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  excerpt   String
  content   String   @db.LongText
  image     String?
  author    String?
  createdAt DateTime @default(now())
}

model Job {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  location    String
  type        String
  experience  String
  description String
  skills      String
  createdAt   DateTime @default(now())
}

model Application {
  id        String   @id @default(uuid())
  name      String
  email     String
  role      String?
  message   String?
  resumeUrl String?
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  service   String?
  message   String
  createdAt DateTime @default(now())
}

