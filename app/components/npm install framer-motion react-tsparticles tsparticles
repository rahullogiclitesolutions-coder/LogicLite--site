"use client"

import Particles from "react-tsparticles"
import { loadSlim } from "tsparticles-slim"
import { useCallback } from "react"

export default function ParticlesBackground(){

const particlesInit = useCallback(async (engine:any)=>{
  await loadSlim(engine)
},[])

return(

<Particles
  id="tsparticles"
  init={particlesInit}
  options={{
    background:{
      color:"transparent"
    },

    fpsLimit:60,

    particles:{
      number:{
        value:40
      },

      color:{
        value:"#60a5fa"
      },

      links:{
        enable:true,
        distance:150,
        color:"#60a5fa",
        opacity:0.2,
        width:1
      },

      move:{
        enable:true,
        speed:1
      },

      opacity:{
        value:0.3
      },

      size:{
        value:2
      }
    }
  }}
/>

)

}